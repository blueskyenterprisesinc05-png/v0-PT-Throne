# Server-only — never prefix with NEXT_PUBLIC_
#
# IMPORTANT: Local .env must match Vercel — copy the same production URL from
# Vercel → Settings → Environment Variables. Do NOT use webhook-test locally
# unless you click "Listen for test event" in n8n immediately before submitting.

# PRODUCTION (workflow must be Active in n8n):
N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/your-webhook-id

# Optional: sent as Authorization: Bearer header to n8n
# N8N_WEBHOOK_SECRET=your-shared-secret

# --- Supabase (primary project: ph-Bolt / v0-PT-Throne) ---
# Dashboard: https://supabase.com/dashboard/project/tjosqmcutstuuaojedeg
NEXT_PUBLIC_SUPABASE_URL=https://tjosqmcutstuuaojedeg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# Legacy anon key also works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Supabase (secondary project: barcelona-session-book) ---
# Use only if working on that app; not required for Zenith Solar / v0-PT-Throne.
# NEXT_PUBLIC_SUPABASE_URL_BARCELONA=https://lfyklgmquleidlhjapbu.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY_BARCELONA=sb_publishable_your-key-here
